{
  "name": "gobeyond",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "vite --config vite.config.mjs",
    "build": "vite build --config vite.config.mjs",
    "preview": "vite preview --config vite.config.mjs",
    "cf:dev": "wrangler pages dev dist --d1=DB",
    "cf:deploy": "wrangler pages deploy dist",
    "cf:migrate:local": "wrangler d1 migrations apply gobeyond-db --local",
    "cf:migrate:remote": "wrangler d1 migrations apply gobeyond-db --remote"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.10",
    "wrangler": "^4.79.0"
  }
}