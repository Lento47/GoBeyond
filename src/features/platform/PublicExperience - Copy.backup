import { useEffect, useMemo, useState } from "react";

function getEmbedUrl(value) {
  const input = String(value ?? "").trim();
  if (!input) {
    return "";
  }

  const iframeMatch = input.match(/src=["']([^"']+)["']/i);
  if (iframeMatch?.[1]) {
    return iframeMatch[1].trim();
  }

  if (/^https?:\/\//i.test(input)) {
    return input;
  }

  return "";
}

function SectionHeading({ eyebrow, title, description, light = false }) {
  return (
    <div className="gobeyond-reveal max-w-3xl">
      <p className={`text-[11px] uppercase tracking-[0.38em] ${light ? "text-[#d3c2ad]" : "text-[#8b6d55]"}`}>{eyebrow}</p>
      <h2
        className={`mt-3 max-w-3xl text-balance font-['Inter'] text-[2.25rem] font-[800] leading-[0.95] tracking-[-0.04em] sm:mt-4 sm:text-4xl lg:text-[3.1rem] ${
          light ? "text-[#f8f2e8]" : "text-[#19131d]"
        }`}
      >
        {title}
      </h2>
      {description ? (
        <p className={`mt-4 max-w-2xl text-[0.98rem] leading-7 sm:mt-5 sm:text-lg sm:leading-8 ${light ? "text-[#e2d5c5]" : "text-[#5f4f48]"}`}>
          {description}
        </p>
      ) : null}
    </div>
  );
}

function Reveal({ as: Component = "div", className = "", children, ...props }) {
  return (
    <Component className={`gobeyond-reveal ${className}`.trim()} {...props}>
      {children}
    </Component>
  );
}

function DesktopRail({ activeSection, navItems, railProgress }) {
  return (
    <aside className="relative hidden self-start lg:block">
      <div className="sticky top-8">
        <div className="max-h-[calc(100vh-4rem)] overflow-y-auto rounded-[2rem] border border-[rgba(216,199,178,0.56)] bg-[rgba(255,251,245,0.76)] p-5 shadow-[0_24px_60px_rgba(90,63,49,0.08)] backdrop-blur-xl">
          <nav className="relative">
            <div className="mb-5 px-3">
              <p className="text-[10px] uppercase tracking-[0.34em] text-[#8b6d55]">Recorrido</p>
              <p className="mt-2 font-['Georgia'] text-2xl text-[#19131d]">GoBeyond</p>
            </div>
            <div className="absolute bottom-2 left-[2.85rem] top-[7.35rem] w-px bg-[linear-gradient(180deg,#eadfd2_0%,#d9cab8_100%)]" />
            <div
              aria-hidden="true"
              className="absolute left-[2.78rem] top-[7.35rem] w-[3px] rounded-full bg-[linear-gradient(180deg,#d6a46e_0%,#1d1720_100%)] transition-[height] duration-300"
              style={{ height: `calc((100% - 8.15rem) * ${railProgress / 100})` }}
            />
            <div className="grid gap-2">
              {navItems.map((item, index) => (
                <a
                  key={item.id}
                  className={`group relative grid grid-cols-[auto_minmax(0,1fr)_auto] items-center gap-4 rounded-[1.35rem] px-3 py-4 transition ${
                    activeSection === item.id
                      ? "bg-[#16131d] text-[#f8f2e8] shadow-[0_18px_40px_rgba(29,23,32,0.18)]"
                      : "text-[#7b685c] hover:bg-[#fff8ef] hover:text-[#1a141d]"
                  }`}
                  href={`#${item.id}`}
                >
                  <span
                    className={`relative z-10 flex h-11 w-11 items-center justify-center rounded-full border text-sm font-semibold transition ${
                      activeSection === item.id
                        ? "border-[#0d6efd] bg-[#0d6efd] text-white"
                        : "border-[#d8ccbf] bg-white text-[#8b6d55] group-hover:border-[#0d6efd] group-hover:text-[#1a141d]"
                    }`}
                  >
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <span className="min-w-0">
                    <span className="block text-[1.1rem] font-medium leading-tight">{item.label}</span>
                    <span className={`mt-1 block text-xs uppercase tracking-[0.22em] ${
                      activeSection === item.id ? "text-[#b8d3ff]" : "text-[#a28f82]"
                    }`}>
                      {activeSection === item.id ? "Seccion activa" : "Ir a seccion"}
                    </span>
                  </span>
                  <span className="flex items-center gap-3">
                    <span
                      className={`h-px w-10 transition ${
                        activeSection === item.id ? "bg-[#69a5ff]" : "bg-[#d8ccbf] group-hover:w-14 group-hover:bg-[#0d6efd]"
                      }`}
                    />
                    <span className={`${activeSection === item.id ? "text-[#69a5ff]" : "text-[#a28f82] group-hover:translate-x-1 group-hover:text-[#0d6efd]"}`}>&rarr;</span>
                  </span>
                </a>
              ))}
            </div>
          </nav>
        </div>
      </div>
    </aside>
  );
}

function ResponsiveSection({ id, title, children, defaultOpen = false }) {
  const [open, setOpen] = useState(defaultOpen);

  return (
    <section className="scroll-mt-28 border-b border-[#ddd1c4] py-10 lg:py-28 xl:py-32" id={id}>
      <div className="lg:hidden">
        <button
          aria-expanded={open}
          className="flex w-full items-center justify-between gap-4 border border-[#e3d8ca] bg-white/80 px-4 py-4 text-left shadow-[0_10px_30px_rgba(90,63,49,0.05)]"
          onClick={() => setOpen((current) => !current)}
          type="button"
        >
          <span className="font-['Georgia'] text-xl text-[#19131d]">{title}</span>
          <span className="text-lg text-[#8b6d55]">{open ? "−" : "+"}</span>
        </button>
        {open ? <div className="mt-6">{children}</div> : null}
      </div>
      <div className="hidden lg:block">{children}</div>
    </section>
  );
}

function TestimonialSubmissionForm({ createTestimonialSubmission }) {
  const [form, setForm] = useState({
    quote: "",
    author: "",
    organization: "",
  });
  const [message, setMessage] = useState("");
  const [error, setError] = useState("");
  const [submitting, setSubmitting] = useState(false);

  async function handleSubmit(event) {
    event.preventDefault();
    setMessage("");
    setError("");
    setSubmitting(true);

    try {
      const response = await createTestimonialSubmission(form);
      setMessage(response.message);
      setForm({
        quote: "",
        author: "",
        organization: "",
      });
    } catch (requestError) {
      setError(requestError.message);
    } finally {
      setSubmitting(false);
    }
  }

  return (
    <form
      className="grid gap-5 rounded-[2rem] border border-white/10 bg-white/8 p-6 shadow-[0_30px_80px_rgba(0,0,0,0.25)] backdrop-blur-xl sm:p-8"
      onSubmit={handleSubmit}
    >
      <p className="text-[11px] uppercase tracking-[0.3em] text-[#d3c2ad]">Comparte tu experiencia</p>
      <textarea
        className="min-h-[160px] rounded-[1.5rem] border border-white/12 bg-[#2b232b]/70 px-5 py-4 text-sm text-[#f8f2e8] outline-none transition placeholder:text-[#978983] focus:border-[#d6a46e] focus:bg-[#332835]"
        value={form.quote}
        onChange={(event) => setForm({ ...form, quote: event.target.value })}
        placeholder="Escribe tu testimonio"
      />
      <div className="grid gap-4 md:grid-cols-2">
        <input
          className="rounded-[999px] border border-white/12 bg-[#2b232b]/70 px-5 py-4 text-sm text-[#f8f2e8] outline-none transition placeholder:text-[#978983] focus:border-[#d6a46e] focus:bg-[#332835]"
          value={form.author}
          onChange={(event) => setForm({ ...form, author: event.target.value })}
          placeholder="Tu nombre"
        />
        <input
          className="rounded-[999px] border border-white/12 bg-[#2b232b]/70 px-5 py-4 text-sm text-[#f8f2e8] outline-none transition placeholder:text-[#978983] focus:border-[#d6a46e] focus:bg-[#332835]"
          value={form.organization}
          onChange={(event) => setForm({ ...form, organization: event.target.value })}
          placeholder="Institucion u organizacion"
        />
      </div>
      <button
        className="w-full rounded-full bg-[#d6a46e] px-6 py-3.5 text-sm font-semibold text-[#1c151d] shadow-[0_14px_30px_rgba(214,164,110,0.35)] transition duration-300 hover:-translate-y-0.5 hover:bg-[#e4b278] hover:shadow-[0_18px_36px_rgba(214,164,110,0.42)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#f4d7b5] sm:w-fit"
        disabled={submitting}
        type="submit"
      >
        {submitting ? "Enviando..." : "Enviar testimonio"}
      </button>
      {message ? <p className="text-sm text-[#bfe0b4]">{message}</p> : null}
      {error ? <p className="text-sm text-[#f2b3a8]">{error}</p> : null}
    </form>
  );
}

export function PublicExperience({ content, createTestimonialSubmission, onRequestLogin }) {
  const { landing } = content;
  const institutions = useMemo(() => content.institutions ?? [], [content.institutions]);
  const featuredInstitutions = useMemo(() => institutions.filter((item) => item.featured), [institutions]);
  const visibleInstitutions = useMemo(
    () => (featuredInstitutions.length ? featuredInstitutions : institutions).slice(0, 3),
    [featuredInstitutions, institutions]
  );
  const hiddenInstitutionCount = Math.max(
    (featuredInstitutions.length ? featuredInstitutions.length : institutions.length) - visibleInstitutions.length,
    0
  );
  const testimonials = useMemo(() => content.testimonials ?? [], [content.testimonials]);
  const institutionCards = useMemo(() => {
    const cards = [];

    if (visibleInstitutions.length) {
      for (const item of visibleInstitutions) {
        cards.push({ type: "institution", item, key: item.id });
      }
    } else {
      cards.push({ type: "empty", key: "institutions-empty" });
    }

    if (hiddenInstitutionCount > 0) {
      cards.push({ type: "summary", key: "institutions-summary" });
    }

    return cards;
  }, [hiddenInstitutionCount, visibleInstitutions]);
  const navItems = useMemo(
    () =>
      landing.nav.map((item) => ({
        label: item,
        id: item.toLowerCase().replaceAll(" ", "-"),
      })),
    [landing.nav]
  );
  const trackedSectionIds = useMemo(() => navItems.map((item) => item.id), [navItems]);
  const [activeSection, setActiveSection] = useState("inicio");
  const [showDesktopRail, setShowDesktopRail] = useState(() =>
    typeof window !== "undefined" ? window.matchMedia("(min-width: 1024px)").matches : true
  );
  const activeSectionIndex = Math.max(
    navItems.findIndex((item) => item.id === activeSection),
    0
  );
  const railProgress = navItems.length > 1 ? (activeSectionIndex / (navItems.length - 1)) * 100 : 0;

  useEffect(() => {
    if (typeof window === "undefined") {
      return undefined;
    }

    let animationFrame = 0;

    const updateActiveSection = () => {
      const sections = trackedSectionIds
        .map((id) => document.getElementById(id))
        .filter(Boolean)
        .map((section) => ({
          id: section.id,
          top: section.offsetTop,
          height: section.offsetHeight,
        }));

      if (!sections.length) {
        return;
      }

      const stickyHeaderOffset = 156;
      const viewportAnchor = window.scrollY + stickyHeaderOffset + window.innerHeight * 0.18;
      const lastSection = sections[sections.length - 1];

      if (window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 24) {
        setActiveSection(lastSection.id);
        return;
      }

      let currentId = sections[0].id;

      for (let index = 0; index < sections.length; index += 1) {
        const section = sections[index];
        const nextSection = sections[index + 1];
        const sectionStart = section.top;
        const sectionEnd = nextSection ? nextSection.top : section.top + Math.max(section.height, window.innerHeight);

        if (viewportAnchor >= sectionStart && viewportAnchor < sectionEnd) {
          currentId = section.id;
          break;
        }
      }

      setActiveSection((previous) => (previous === currentId ? previous : currentId));
    };

    const requestUpdate = () => {
      if (animationFrame) {
        return;
      }

      animationFrame = window.requestAnimationFrame(() => {
        animationFrame = 0;
        updateActiveSection();
      });
    };

    updateActiveSection();
    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);

    return () => {
      if (animationFrame) {
        window.cancelAnimationFrame(animationFrame);
      }
      window.removeEventListener("scroll", requestUpdate);
      window.removeEventListener("resize", requestUpdate);
    };
  }, [trackedSectionIds]);

  useEffect(() => {
    if (typeof window === "undefined") {
      return undefined;
    }

    const elements = Array.from(document.querySelectorAll(".gobeyond-reveal"));
    if (!elements.length) {
      return undefined;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
          }
        });
      },
      {
        rootMargin: "0px 0px -12% 0px",
        threshold: 0.12,
      }
    );

    elements.forEach((element) => observer.observe(element));

    return () => observer.disconnect();
  }, [content]);

  useEffect(() => {
    if (typeof window === "undefined") {
      return undefined;
    }

    const mediaQuery = window.matchMedia("(min-width: 1024px)");
    const syncRail = (event) => setShowDesktopRail(event.matches);

    setShowDesktopRail(mediaQuery.matches);

    if (typeof mediaQuery.addEventListener === "function") {
      mediaQuery.addEventListener("change", syncRail);
      return () => mediaQuery.removeEventListener("change", syncRail);
    }

    mediaQuery.addListener(syncRail);
    return () => mediaQuery.removeListener(syncRail);
  }, []);

  return (
    <div className="min-h-screen overflow-x-hidden bg-[radial-gradient(circle_at_top,#ffffff_0%,rgba(247,242,234,0.94)_28%,#efe5d6_100%)] text-[#1a141d]">
      <header className="relative border-b border-[#dccfbe] bg-[#f8f3eb]/96 shadow-[0_12px_36px_rgba(51,33,27,0.06)]">
        <div className="mx-auto flex max-w-[96rem] flex-col gap-4 px-4 py-4 sm:px-6 sm:py-5 lg:px-8 xl:px-10">
          <a className="group flex min-w-0 items-start gap-3 sm:gap-4" href="#inicio">
            <div className="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-[radial-gradient(circle_at_top,#ffffff_0%,#efe4d6_100%)] shadow-[0_12px_30px_rgba(36,24,31,0.08)] ring-1 ring-[#dccab5] transition duration-300 group-hover:-translate-y-0.5 group-hover:shadow-[0_18px_36px_rgba(36,24,31,0.12)] sm:h-14 sm:w-14">
              <img alt="Logo de GoBeyond" className="h-8 w-8 object-contain sm:h-10 sm:w-10" src="/favicon.png" />
            </div>
            <div className="min-w-0 flex-1">
              <p className="truncate text-[10px] uppercase tracking-[0.28em] text-[#8b6d55] sm:text-[11px] sm:tracking-[0.38em]">{content.brand.name}</p>
              <p className="mt-1 line-clamp-2 max-w-2xl text-xs leading-5 text-[#67584f] sm:text-sm sm:leading-6">
                {content.brand.description}
              </p>
            </div>
          </a>

          <button
            className="w-full rounded-full border border-[#231a22] bg-white/70 px-4 py-2.5 text-sm font-medium text-[#231a22] shadow-[0_10px_24px_rgba(25,19,29,0.08)] transition duration-300 hover:-translate-y-0.5 hover:bg-[#231a22] hover:text-white hover:shadow-[0_16px_28px_rgba(25,19,29,0.18)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#b4875b] sm:w-fit sm:self-end lg:hidden"
            onClick={onRequestLogin}
            type="button"
          >
            Ingresar
          </button>
        </div>
        <div className="border-t border-[#eadfd2] px-4 py-3 sm:px-6 lg:hidden">
          <nav aria-label="Secciones" className="-mx-4 flex gap-2 overflow-x-auto px-4 pb-1">
            {navItems.map((item) => (
              <a
                key={item.id}
                className={`shrink-0 rounded-full border px-4 py-2 text-xs font-medium uppercase tracking-[0.18em] transition ${
                  activeSection === item.id
                    ? "border-[#1f1720] bg-[#1f1720] text-[#f8f2e8]"
                    : "border-[#d8ccbf] bg-white/80 text-[#6d5a51]"
                }`}
                href={`#${item.id}`}
              >
                {item.label}
              </a>
            ))}
          </nav>
        </div>
        <div className="h-4 bg-[linear-gradient(180deg,rgba(248,243,235,1)_0%,rgba(248,243,235,0.68)_45%,rgba(248,243,235,0)_100%)] sm:h-6" />
      </header>

      <div className="pointer-events-none fixed right-6 top-6 z-50 hidden lg:block">
        <button
          className="pointer-events-auto rounded-full border border-[rgba(13,110,253,0.24)] bg-[#0d6efd] px-5 py-3 text-sm font-semibold text-white shadow-[0_12px_28px_rgba(13,110,253,0.28)] backdrop-blur-md transition duration-300 hover:-translate-y-0.5 hover:bg-[#0a5ad4]"
          onClick={onRequestLogin}
          type="button"
        >
          Ingresar
        </button>
      </div>

      <main>
        <div className="mx-auto max-w-[96rem] px-4 py-8 sm:px-6 sm:py-10 lg:grid lg:grid-cols-[280px_minmax(0,1fr)] lg:items-start lg:gap-12 lg:px-8 lg:py-12 xl:grid-cols-[320px_minmax(0,1fr)] xl:gap-16 xl:px-10 xl:py-16">
          {showDesktopRail ? <DesktopRail activeSection={activeSection} navItems={navItems} railProgress={railProgress} /> : null}

          <div className="min-w-0 lg:space-y-8">
        <section className="relative overflow-hidden rounded-[2.25rem] bg-[linear-gradient(145deg,#0f1117_0%,#141821_52%,#17131b_100%)] text-[#f8f2e8] shadow-[0_30px_80px_rgba(28,20,17,0.18)] lg:rounded-[2.6rem]" id="inicio">
          <div className="absolute inset-0 bg-[radial-gradient(circle_at_14%_18%,rgba(13,110,253,0.18),transparent_22%),radial-gradient(circle_at_82%_24%,rgba(77,126,255,0.28),transparent_28%),radial-gradient(circle_at_72%_82%,rgba(214,164,110,0.12),transparent_24%)]" />
          <div className="absolute -right-20 top-20 h-72 w-72 rounded-full bg-[radial-gradient(circle,#4d7eff_0%,rgba(77,126,255,0.12)_52%,transparent_72%)] blur-2xl" />
          <div className="absolute inset-x-0 bottom-0 h-40 bg-[linear-gradient(180deg,rgba(17,19,25,0)_0%,rgba(17,19,25,0.84)_100%)]" />

          <div className="relative grid gap-8 px-4 pb-12 pt-10 sm:px-6 sm:pb-16 sm:pt-12 lg:grid-cols-[1.08fr_0.92fr] lg:items-end lg:gap-10 lg:px-10 lg:pb-24 lg:pt-16 xl:gap-12 xl:px-12 xl:pt-20">
            <Reveal className="max-w-3xl">
              <p className="text-[11px] uppercase tracking-[0.42em] text-[#d6bf9b]">{content.hero.eyebrow}</p>
              <h1 className="mt-5 max-w-4xl text-balance font-['Inter'] text-[3.25rem] font-[800] leading-[0.88] tracking-[-0.06em] sm:mt-6 sm:text-[4.5rem] lg:text-[5.6rem]">
                {content.hero.title}
              </h1>
              <p className="mt-6 max-w-2xl text-[1rem] font-[400] leading-8 text-[#d9dbe4] sm:text-[1.12rem]">{content.hero.description}</p>

              <div className="mt-8 flex flex-col gap-3 sm:mt-10 sm:flex-row sm:flex-wrap sm:gap-4">
                <a
                  className="rounded-full bg-[#0d6efd] px-6 py-3.5 text-center text-sm font-semibold text-white shadow-[0_18px_36px_rgba(13,110,253,0.3)] transition duration-300 ease-out hover:-translate-y-0.5 hover:bg-[#0a5ad4]"
                  href="#contacto"
                >
                  Ponte en contacto
                </a>
                <a
                  className="rounded-full border border-white/16 bg-white/5 px-6 py-3.5 text-center text-sm text-[#f8f2e8] backdrop-blur-sm transition duration-300 ease-out hover:-translate-y-0.5 hover:border-[#7eb1ff] hover:bg-white/10"
                  href="#cursos"
                >
                  Explorar programas
                </a>
              </div>
            </Reveal>

            <Reveal className="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
              {content.hero.metrics.map((metric, index) => (
                <div
                  key={metric.label}
                  className={`gobeyond-glass rounded-[1.6rem] p-5 transition duration-300 ease-out hover:-translate-y-1.5 hover:border-[rgba(126,177,255,0.28)] hover:bg-white/[0.07] sm:p-6 ${
                    index === 1 ? "lg:ml-8" : index === 2 ? "lg:ml-16" : ""
                  }`}
                >
                  <p className="text-[11px] uppercase tracking-[0.28em] text-[#c7b49c]">{metric.label}</p>
                  <p className="mt-4 text-3xl font-semibold text-white">{metric.value}</p>
                  <p className="mt-3 text-sm leading-7 text-[#ddd0c3]">{metric.description}</p>
                </div>
              ))}
            </Reveal>
          </div>
        </section>

        <div className="overflow-hidden rounded-[2.2rem] border border-[rgba(216,199,178,0.42)] bg-white/34 shadow-[0_24px_60px_rgba(90,63,49,0.05)] backdrop-blur-[4px]">
        <div className="grid gap-0">
            <ResponsiveSection defaultOpen id="sobre-nosotros" title={landing.aboutTitle}>
              <div className="grid gap-12 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
                <SectionHeading eyebrow={landing.aboutTitle} title={content.brand.tagline} description={landing.aboutBody} />

                <div className="grid gap-8">
                  <div className="rounded-[2rem] bg-white/65 p-6 shadow-[0_24px_55px_rgba(65,44,35,0.08)] ring-1 ring-[#eadfd2] backdrop-blur-sm sm:p-8">
                    <p className="text-base leading-7 text-[#5f4f48] sm:text-lg sm:leading-8">{landing.aboutBodyTwo}</p>
                    <p className="mt-5 text-base leading-7 text-[#5f4f48] sm:mt-6 sm:text-lg sm:leading-8">
                      Nuestro objetivo es claro: abrir oportunidades reales de formacion especializada, reducir brechas en el acceso a certificaciones internacionales y contribuir al fortalecimiento de la empleabilidad y competitividad de la juventud.
                    </p>
                  </div>

                  <div className="grid gap-4 sm:grid-cols-2">
                    {content.benefits.map((item) => (
                      <div
                        key={item}
                        className="rounded-[1.5rem] border border-[#eadfd2] bg-[#fffdf8]/90 p-5 text-sm leading-7 text-[#5f4f48] shadow-[0_18px_40px_rgba(120,84,60,0.05)] transition duration-300 hover:-translate-y-1 hover:border-[#d6a46e] hover:shadow-[0_24px_44px_rgba(120,84,60,0.1)]"
                      >
                        {item}
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </ResponsiveSection>

            <ResponsiveSection id="servicios" title={landing.servicesTitle}>
              <SectionHeading
                eyebrow={landing.servicesTitle}
                title="Capacitacion alineada con las necesidades reales del mercado."
                description={landing.relevanceBody}
              />

              <div className="mt-8 grid gap-4 sm:mt-10 sm:grid-cols-2 lg:mt-12 lg:grid-cols-3">
                {content.learningPath.map((item) => (
                  <article
                    key={item.id}
                    className="group rounded-[1.8rem] border border-[#e7dbcf] bg-[linear-gradient(180deg,#fffcf7_0%,#f7efe5_100%)] p-6 shadow-[0_20px_50px_rgba(104,72,54,0.06)] transition duration-300 hover:-translate-y-1.5 hover:border-[#c99b70] hover:shadow-[0_28px_56px_rgba(104,72,54,0.12)] sm:p-7"
                  >
                    <p className="text-[11px] uppercase tracking-[0.3em] text-[#8b6d55]">{item.type}</p>
                    <h3 className="mt-4 font-['Georgia'] text-[1.7rem] leading-tight text-[#19131d] sm:text-[1.9rem]">{item.title}</h3>
                    <p className="mt-5 text-base leading-8 text-[#5f4f48]">{item.status}</p>
                    <div className="mt-8 h-px w-16 bg-[#d8ccbf] transition duration-300 group-hover:w-24 group-hover:bg-[#d6a46e]" />
                  </article>
                ))}
              </div>
            </ResponsiveSection>

            <ResponsiveSection id="cursos" title={landing.coursesTitle}>
              <SectionHeading
                eyebrow={landing.coursesTitle}
                title="Programas creados para preparar talento con impacto real."
                description="El equipo administrativo puede construir y actualizar esta oferta directamente desde la plataforma, con enfoque academico, profesional y social."
              />

              <div className="mt-8 grid gap-4 sm:mt-10 sm:grid-cols-2 lg:mt-12">
                {(content.courses ?? []).map((course) => (
                  <article
                    key={course.id}
                    className="group rounded-[2rem] border border-[#e7dbcf] bg-white/90 p-6 shadow-[0_24px_60px_rgba(90,63,49,0.08)] ring-1 ring-white/70 backdrop-blur-sm transition duration-300 hover:-translate-y-1.5 hover:border-[#c99b70] hover:shadow-[0_30px_70px_rgba(90,63,49,0.14)] sm:p-8"
                  >
                    <div className="flex flex-wrap items-center gap-3 text-[11px] uppercase tracking-[0.28em] text-[#8b6d55]">
                      <span>{course.format}</span>
                      <span className="h-1 w-1 rounded-full bg-[#c49c73]" />
                      <span>{course.duration}</span>
                    </div>
                    <h3 className="mt-5 font-['Georgia'] text-[1.8rem] leading-tight text-[#19131d] sm:text-[2rem]">{course.title}</h3>
                    <p className="mt-4 text-sm uppercase tracking-[0.2em] text-[#8b6d55]">{course.audience}</p>
                    <p className="mt-5 text-base leading-8 text-[#5f4f48]">{course.description}</p>
                    <div className="mt-8 border-t border-[#efe2d4] pt-5 text-sm leading-7 text-[#5f4f48]">
                      <strong className="text-[#19131d]">Resultados esperados:</strong> {course.outcomes}
                    </div>
                  </article>
                ))}
              </div>
            </ResponsiveSection>

            <ResponsiveSection id="impacto" title="Impacto">
              <div className="grid gap-6 lg:grid-cols-[1.08fr_0.92fr]">
                <div className="rounded-[2rem] bg-[linear-gradient(180deg,#1d1720_0%,#251d24_100%)] p-8 text-[#f8f2e8] shadow-[0_32px_80px_rgba(19,13,21,0.28)] lg:p-10">
                  <SectionHeading
                    eyebrow="Nuestro impacto"
                    title="Compromiso social y educativo con oportunidades concretas."
                    description="Go Beyond impulsa programas becados para instituciones publicas y planes accesibles para organizaciones privadas con una vision clara de retorno social y profesional."
                    light
                  />

                  <div className="mt-10 space-y-6">
                    {content.accessTimeline.map((step) => (
                      <div key={step.id} className="rounded-[1.5rem] border border-white/8 bg-white/[0.04] p-5 backdrop-blur-sm">
                        <p className="text-[11px] uppercase tracking-[0.28em] text-[#d6bf9b]">{step.label}</p>
                        <h3 className="mt-3 text-xl font-medium text-white">{step.title}</h3>
                        <p className="mt-3 leading-7 text-[#e2d5c5]">{step.description}</p>
                      </div>
                    ))}
                  </div>
                </div>

                <div className="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
                  {content.communityStats.map((item) => (
                    <div
                      key={item.id}
                      className="rounded-[1.75rem] border border-[#e7dbcf] bg-white/75 p-6 shadow-[0_18px_44px_rgba(90,63,49,0.06)] backdrop-blur-sm transition duration-300 hover:-translate-y-1 hover:border-[#c99b70]"
                    >
                      <p className="text-[11px] uppercase tracking-[0.28em] text-[#8b6d55]">{item.label}</p>
                      <h3 className="mt-4 font-['Georgia'] text-3xl leading-tight text-[#19131d]">{item.value}</h3>
                      <p className="mt-4 text-base leading-7 text-[#5f4f48]">{item.description}</p>
                    </div>
                  ))}
                </div>
              </div>
            </ResponsiveSection>

            <ResponsiveSection id="testimonios" title={landing.testimonialTitle}>
              <div className="grid items-start gap-8 lg:grid-cols-[1.08fr_0.92fr] xl:grid-cols-[1.02fr_0.98fr]">
                <div>
                  <SectionHeading
                    eyebrow={landing.trustTitle}
                    title="Instituciones y comunidades que creen en este cambio."
                    description="Go Beyond busca fortalecer el prestigio institucional y la preparacion del estudiantado con una oferta formativa conectada al futuro laboral."
                  />

                    <div className="mt-8 grid gap-5 xl:grid-cols-2">
                      {institutionCards.map((entry, index) => {
                        if (entry.type === "institution") {
                          const { item } = entry;
                          const Wrapper = item.link ? "a" : "article";
                          const embedUrl = getEmbedUrl(item.embed);
                          const featuredCardClass =
                            institutionCards.length >= 3 && index === 0 ? "xl:col-span-2" : "";

                          return (
                            <Wrapper
                              key={entry.key}
                              {...(item.link ? { href: item.link, target: "_blank", rel: "noreferrer" } : {})}
                              className={`group overflow-hidden rounded-[1.7rem] border border-[#e1d3c4] bg-white/90 shadow-[0_18px_40px_rgba(90,63,49,0.06)] transition duration-300 hover:-translate-y-1 hover:border-[#c99b70] hover:shadow-[0_26px_52px_rgba(90,63,49,0.12)] ${featuredCardClass}`}
                            >
                              {embedUrl ? (
                                <div className="h-[21rem] overflow-hidden bg-[#edf1f4] sm:h-[24rem] xl:h-[22rem]">
                                  <iframe
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                    allowFullScreen
                                    className="h-full w-full border-0"
                                    height="100%"
                                    referrerPolicy="strict-origin-when-cross-origin"
                                    src={embedUrl}
                                    title={item.name}
                                    width="100%"
                                  />
                                </div>
                              ) : item.image ? (
                                <div className="aspect-[16/9] overflow-hidden bg-[#edf1f4]">
                                  <img
                                    alt={item.name}
                                    className="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                                    src={item.image}
                                  />
                                </div>
                              ) : (
                                <div className="aspect-[16/9] bg-[linear-gradient(135deg,#f3e6d7_0%,#efe5db_100%)]" />
                              )}
                              <div className="flex items-center justify-between gap-4 px-5 py-4">
                                <div>
                                  <p className="text-[11px] uppercase tracking-[0.28em] text-[#8b6d55]">
                                    {embedUrl ? "Institucion aliada · Embed" : item.link ? "Institucion aliada · Referencia" : "Institucion aliada"}
                                  </p>
                                  <p className="mt-2 text-base font-medium text-[#19131d]">{item.name}</p>
                                </div>
                                <span className="text-[#b4875b] transition duration-300 group-hover:translate-x-1">&rarr;</span>
                              </div>
                            </Wrapper>
                          );
                        }

                        if (entry.type === "summary") {
                          return (
                            <div key={entry.key} className="rounded-[1.4rem] border border-[#e1d3c4] bg-[#fffaf3] px-5 py-4 text-sm leading-7 text-[#5f4f48]">
                              +{hiddenInstitutionCount} instituciones adicionales forman parte de la red y se mantienen ordenadas desde la cabina administrativa.
                            </div>
                          );
                        }

                        return (
                          <div key={entry.key} className="rounded-[1.7rem] border border-dashed border-[#d8ccbf] bg-white/70 p-6 text-sm text-[#6d5a51]">
                            Las instituciones aliadas que agregues desde admin apareceran aqui.
                          </div>
                        );
                      })}
                    </div>
                </div>

                <div className="grid gap-4">
                  {(content.news ?? []).length ? (
                    <div className="grid gap-4">
                      <p className="text-[11px] uppercase tracking-[0.32em] text-[#8b6d55]">Noticias</p>
                      <div className="grid gap-4">
                      {(content.news ?? []).map((item) => (
                        <article
                          key={item.id}
                          className="overflow-hidden rounded-[1.9rem] border border-[#e6d8ca] bg-white shadow-[0_24px_60px_rgba(90,63,49,0.1)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_30px_70px_rgba(90,63,49,0.12)]"
                        >
                          {getEmbedUrl(item.embed) ? (
                            <div className="aspect-[16/9] overflow-hidden bg-[#efe4d6]">
                              <iframe
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                allowFullScreen
                                className="h-full w-full border-0"
                                referrerPolicy="strict-origin-when-cross-origin"
                                src={getEmbedUrl(item.embed)}
                                title={item.title}
                              />
                            </div>
                          ) : item.image ? (
                            <div className="aspect-[16/9] overflow-hidden bg-[#efe4d6]">
                              <img alt={item.title} className="h-full w-full object-cover" src={item.image} />
                            </div>
                          ) : null}
                          <div className="p-6 sm:p-8">
                            <p className="text-[11px] uppercase tracking-[0.28em] text-[#8b6d55]">{item.category || "Noticia"}</p>
                            <h3 className="mt-4 font-['Georgia'] text-[2rem] leading-tight text-[#19131d] sm:text-3xl">{item.title}</h3>
                            <p className="mt-4 text-base leading-8 text-[#5f4f48]">{item.summary}</p>
                            {item.link ? (
                              <a
                                className="mt-6 inline-flex items-center gap-2 text-sm font-medium text-[#b06d38] transition hover:gap-3"
                                href={item.link}
                                rel="noreferrer"
                                target="_blank"
                              >
                                Ver referencia
                                <span>&rarr;</span>
                              </a>
                            ) : null}
                          </div>
                        </article>
                      ))}
                      </div>
                    </div>
                  ) : null}

                  <p className="text-[11px] uppercase tracking-[0.32em] text-[#8b6d55]">{landing.testimonialTitle}</p>
                  <div className={`grid items-start gap-4 ${testimonials.length > 1 ? "xl:grid-cols-2" : ""}`}>
                  {testimonials.map((item, index) => (
                    <article
                      key={item.id}
                      className={`self-start rounded-[1.9rem] border border-[#e6d8ca] p-6 transition duration-300 hover:-translate-y-1 hover:shadow-[0_30px_70px_rgba(90,63,49,0.12)] sm:p-7 ${
                        index === 0
                          ? testimonials.length === 1
                            ? "bg-white shadow-[0_24px_60px_rgba(90,63,49,0.1)]"
                            : "border-l-4 border-[#d6a46e] bg-white shadow-[0_24px_60px_rgba(90,63,49,0.1)]"
                          : "bg-[#fffaf3]"
                      }`}
                    >
                      <div className="flex flex-col">
                        <span className="font-['Georgia'] text-[5rem] leading-none text-[#e8d5bf] select-none -mb-6 block">"</span>
                        <blockquote
                          className={`font-['Georgia'] text-[#19131d] ${
                            testimonials.length === 1
                              ? "max-w-[28rem] text-[1.42rem] leading-8 sm:max-w-[30rem] sm:text-[1.62rem] sm:leading-9"
                              : "text-[1.45rem] leading-8 sm:text-[1.7rem] sm:leading-9"
                          }`}
                        >
                          “{item.quote}”
                        </blockquote>
                        <div className="mt-5 flex items-center gap-4 border-t border-[#efe2d4] pt-4">
                          <div className="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-[radial-gradient(circle_at_30%_30%,#fff6e8_0%,#ead5bc_100%)] text-sm font-semibold text-[#8b6d55] ring-1 ring-[#dfc6ab]">
                            {String(item.author ?? "")
                              .trim()
                              .split(/\s+/)
                              .filter(Boolean)
                              .slice(0, 2)
                              .map((part) => part[0]?.toUpperCase() ?? "")
                              .join("")}
                          </div>
                          <div className="min-w-0">
                            <p className="text-sm uppercase tracking-[0.2em] text-[#8b6d55]">
                              {item.author}
                              {item.organization ? <span className="mx-1.5 text-[#c9b09a]">·</span> : null}
                              <span className="text-[#5f4f48]">{item.organization}</span>
                            </p>
                          </div>
                        </div>
                      </div>
                    </article>
                  ))}
                  </div>
                </div>
              </div>
            </ResponsiveSection>

            <ResponsiveSection id="inicio-detalle" title={landing.relevanceTitle}>
              <SectionHeading eyebrow={landing.relevanceTitle} title={content.subscription.label} description={content.subscription.description} />

              <div className="mt-8 grid gap-4 sm:mt-10 sm:grid-cols-3">
                {content.liveSessions.map((item) => (
                  <div
                    key={item.id}
                    className="rounded-[1.5rem] border border-[#e7dbcf] bg-[linear-gradient(180deg,#fffdf8_0%,#f8efe3_100%)] p-6 shadow-[0_18px_38px_rgba(90,63,49,0.05)] transition duration-300 hover:-translate-y-1 hover:border-[#c99b70]"
                  >
                    <p className="text-[11px] uppercase tracking-[0.28em] text-[#8b6d55]">{item.date}</p>
                    <h3 className="mt-4 text-2xl font-semibold text-[#19131d]">{item.title}</h3>
                    <p className="mt-3 text-sm text-[#5f4f48]">{item.format}</p>
                  </div>
                ))}
              </div>
            </ResponsiveSection>

            <ResponsiveSection id="contacto" title={landing.contactTitle}>
              <div className="overflow-hidden rounded-[2.4rem] bg-[linear-gradient(180deg,#1b151d_0%,#241c24_100%)] px-5 py-8 text-[#f8f2e8] shadow-[0_40px_90px_rgba(19,13,21,0.28)] sm:px-8 sm:py-10 lg:px-10 lg:py-12">
                <div className="grid gap-10 lg:grid-cols-[0.92fr_1.08fr]">
                  <div className="space-y-8">
                    <SectionHeading
                      eyebrow={landing.contactTitle}
                      title="Ponte en contacto y ayudanos a ampliar oportunidades."
                      description={landing.contactBody}
                      light
                    />

                    <div className="grid gap-4">
                      {landing.contactActions.map((item) => (
                        <a
                          key={item}
                          className="group flex items-center justify-between rounded-[1.4rem] border border-white/10 bg-white/[0.03] px-5 py-4 text-sm text-[#f8f2e8] backdrop-blur-sm transition duration-300 hover:-translate-y-0.5 hover:border-[#d6a46e] hover:bg-white/[0.05]"
                          href="#inicio"
                        >
                          <span>{item}</span>
                          <span className="text-[#d6bf9b] transition duration-300 group-hover:translate-x-1">Explorar</span>
                        </a>
                      ))}
                    </div>
                  </div>

                  <TestimonialSubmissionForm createTestimonialSubmission={createTestimonialSubmission} />
                </div>
              </div>
            </ResponsiveSection>
          </div>

            <div className="flex justify-center border-b border-[#ddd1c4] py-10 lg:py-14">
              <a
                className="inline-flex items-center gap-3 rounded-full border border-[#1f1720] bg-white/85 px-6 py-3 text-sm font-semibold text-[#1f1720] shadow-[0_14px_30px_rgba(31,23,32,0.08)] transition duration-300 hover:-translate-y-0.5 hover:bg-[#1f1720] hover:text-white"
              href="#inicio"
            >
              Volver arriba
              <span aria-hidden="true">↑</span>
              </a>
            </div>
        </div>
        </div>
        </div>
      </main>
    </div>
  );
}
