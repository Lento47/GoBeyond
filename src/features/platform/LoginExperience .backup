import { useState } from "react";

// Input optimizado con estilo Minimalista/Apple
function Input(props) {
  return (
    <input 
      className="w-full bg-white/[0.03] border border-white/10 rounded-xl px-4 py-4 text-sm text-white placeholder:text-gray-600 focus:outline-none focus:border-blue-500 focus:bg-white/[0.05] transition-all duration-300" 
      {...props} 
    />
  );
}

export function LoginExperience({ authLoading, error, mode, onBack, onLogin, onModeChange, onRegister }) {
  const [loginForm, setLoginForm] = useState({
    email: "",
    password: "",
  });
  const [registerForm, setRegisterForm] = useState({
    fullName: "",
    email: "",
    password: "",
  });

  async function handleLogin(event) {
    event.preventDefault();
    await onLogin(loginForm);
  }

  async function handleRegister(event) {
    event.preventDefault();
    await onRegister(registerForm);
  }

  return (
    <div className="min-h-screen bg-[#050505] text-white font-sans selection:bg-blue-500/30 relative overflow-hidden flex flex-col">
      
      {/* Elementos decorativos de fondo (Glows) */}
      <div className="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-blue-600/10 rounded-full blur-[120px] pointer-events-none" />
      <div className="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-blue-900/10 rounded-full blur-[120px] pointer-events-none" />

      {/* Header / Nav */}
      <header className="relative z-10 w-full max-w-7xl mx-auto px-8 py-10 flex items-center justify-between">
        <button className="flex items-center gap-4 group" onClick={onBack} type="button">
          <div className="h-10 w-10 bg-blue-600 rounded-xl flex items-center justify-center shadow-[0_0_20px_rgba(37,99,235,0.3)] transition-transform group-hover:scale-110">
             <div className="h-5 w-5 border-2 border-white rounded-sm" />
          </div>
          <div className="text-left">
            <p className="text-[10px] font-black uppercase tracking-[0.4em] text-blue-500">GoBeyond</p>
            <p className="text-[10px] font-bold uppercase tracking-widest text-gray-500 group-hover:text-white transition-colors">Volver al inicio</p>
          </div>
        </button>

        <button 
          className="text-[10px] font-bold uppercase tracking-widest px-6 py-2.5 border border-white/10 rounded-full hover:bg-white hover:text-black transition-all"
          onClick={onBack} 
          type="button"
        >
          Landing Page
        </button>
      </header>

      {/* Main Content */}
      <main className="relative z-10 flex-1 flex items-center">
        <div className="max-w-7xl mx-auto px-8 w-full grid gap-16 lg:grid-cols-[1fr_0.8fr] items-center">
          
          {/* Bloque Izquierdo: Editorial */}
          <div className="max-w-xl gobeyond-reveal">
            <span className="text-[10px] font-bold uppercase tracking-[0.5em] text-blue-500 mb-6 block">Portal de acceso</span>
            <h1 className="text-5xl md:text-7xl font-black leading-[0.9] tracking-[-0.05em] mb-8">
              UN SOLO ACCESO,<br />
              <span className="text-[#222]">DESTINO PRIVADO.</span>
            </h1>
            <p className="text-lg text-gray-400 font-light leading-relaxed mb-10 max-w-lg">
              Usa tus credenciales para entrar. El sistema identificará tu rol y te llevará a tu espacio personal sin exponer rutas sensibles.
            </p>

            <div className="grid gap-6 sm:grid-cols-2">
              <div className="p-6 border border-white/5 bg-white/[0.02] rounded-3xl">
                <p className="text-[9px] font-black uppercase tracking-widest text-blue-500 mb-3">Acceso protegido</p>
                <p className="text-xs text-gray-500 leading-relaxed">Validación real en backend con sesiones cifradas y roles dinámicos.</p>
              </div>
              <div className="p-6 border border-white/5 bg-white/[0.02] rounded-3xl">
                <p className="text-[9px] font-black uppercase tracking-widest text-blue-500 mb-3">Cuenta nueva</p>
                <p className="text-xs text-gray-500 leading-relaxed">¿Eres nuevo estudiante? Registra tu acceso oficial en segundos.</p>
              </div>
            </div>
          </div>

          {/* Bloque Derecho: Formulario Glassmorphism */}
          <div className="relative">
            <div className="absolute inset-0 bg-blue-600/5 blur-[80px] -z-10 rounded-full" />
            
            <div className="border border-white/10 bg-white/[0.02] backdrop-blur-3xl p-10 rounded-[2.5rem] shadow-2xl">
              <div className="flex gap-2 mb-10 p-1.5 bg-white/5 rounded-2xl w-fit">
                <button
                  className={`px-6 py-2.5 text-[10px] font-bold uppercase tracking-widest rounded-xl transition-all ${mode === "login" ? "bg-white text-black shadow-lg" : "text-gray-500 hover:text-white"}`}
                  onClick={() => onModeChange("login")}
                  type="button"
                >
                  Ingresar
                </button>
                <button
                  className={`px-6 py-2.5 text-[10px] font-bold uppercase tracking-widest rounded-xl transition-all ${mode === "register" ? "bg-white text-black shadow-lg" : "text-gray-500 hover:text-white"}`}
                  onClick={() => onModeChange("register")}
                  type="button"
                >
                  Crear cuenta
                </button>
              </div>

              {mode === "register" ? (
                <form className="grid gap-5" onSubmit={handleRegister}>
                  <div className="space-y-1">
                    <label className="text-[9px] uppercase tracking-widest text-gray-500 font-bold ml-1">Nombre Completo</label>
                    <Input
                      value={registerForm.fullName}
                      onChange={(event) => setRegisterForm({ ...registerForm, fullName: event.target.value })}
                      placeholder="Ej. Lejzer Traña"
                    />
                  </div>
                  <div className="space-y-1">
                    <label className="text-[9px] uppercase tracking-widest text-gray-500 font-bold ml-1">Email Institucional</label>
                    <Input
                      value={registerForm.email}
                      onChange={(event) => setRegisterForm({ ...registerForm, email: event.target.value })}
                      placeholder="nombre@gobeyond.com"
                    />
                  </div>
                  <div className="space-y-1">
                    <label className="text-[9px] uppercase tracking-widest text-gray-500 font-bold ml-1">Contraseña</label>
                    <Input
                      type="password"
                      value={registerForm.password}
                      onChange={(event) => setRegisterForm({ ...registerForm, password: event.target.value })}
                      placeholder="••••••••"
                    />
                  </div>
                  <button 
                    className="mt-4 w-full bg-blue-600 py-4 text-sm font-black text-white rounded-xl shadow-[0_10px_30px_rgba(37,99,235,0.3)] hover:bg-blue-500 hover:-translate-y-0.5 transition-all disabled:opacity-50" 
                    disabled={authLoading} 
                    type="submit"
                  >
                    {authLoading ? "PROCESANDO..." : "CREAR CUENTA"}
                  </button>
                </form>
              ) : (
                <form className="grid gap-5" onSubmit={handleLogin}>
                  <div className="space-y-1">
                    <label className="text-[9px] uppercase tracking-widest text-gray-500 font-bold ml-1">Correo Electrónico</label>
                    <Input
                      value={loginForm.email}
                      onChange={(event) => setLoginForm({ ...loginForm, email: event.target.value })}
                      placeholder="usuario@dominio.com"
                    />
                  </div>
                  <div className="space-y-1">
                    <label className="text-[9px] uppercase tracking-widest text-gray-500 font-bold ml-1">Contraseña</label>
                    <Input
                      type="password"
                      value={loginForm.password}
                      onChange={(event) => setLoginForm({ ...loginForm, password: event.target.value })}
                      placeholder="••••••••"
                    />
                  </div>
                  <button 
                    className="mt-4 w-full bg-blue-600 py-4 text-sm font-black text-white rounded-xl shadow-[0_10px_30px_rgba(37,99,235,0.3)] hover:bg-blue-500 hover:-translate-y-0.5 transition-all disabled:opacity-50" 
                    disabled={authLoading} 
                    type="submit"
                  >
                    {authLoading ? "ENTRANDO..." : "INGRESAR AL PORTAL"}
                  </button>
                </form>
              )}

              {error && (
                <div className="mt-6 p-4 bg-red-500/10 border border-red-500/20 rounded-xl">
                  <p className="text-xs text-red-400 font-medium text-center">{error}</p>
                </div>
              )}
            </div>
          </div>
        </div>
      </main>

      <footer className="relative z-10 py-10 text-center">
        <p className="text-[9px] uppercase tracking-[0.5em] text-gray-600">
          © 2026 GOBEYOND ACADEMY · SECURE ACCESS GATEWAY
        </p>
      </footer>

      <style>{`
        .gobeyond-reveal {
          animation: reveal 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        @keyframes reveal {
          from { opacity: 0; transform: translateY(20px); }
          to { opacity: 1; transform: translateY(0); }
        }
      `}</style>
    </div>
  );
}