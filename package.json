{
  "name": "gobeyond",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "vite --config vite.config.mjs",
    "build": "vite build --config vite.config.mjs",
    "preview": "vite preview --config vite.config.mjs",
    "cf:dev": "wrangler pages dev dist --d1=DB --ai=AI",
    "cf:deploy": "wrangler pages deploy dist",
    "cf:migrate:local": "wrangler d1 migrations apply gobeyond-db --local",
    "cf:migrate:remote": "wrangler d1 migrations apply gobeyond-db --remote"
  },
  "dependencies": {
    "animejs": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^6.4.1",
    "wrangler": "^4.12.0"
  }
}
